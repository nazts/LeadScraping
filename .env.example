# ============================================================
# LeadScraping - Environment Variables
# ============================================================
# Copy this file to ".env" and fill in your actual values.
# NEVER commit your real ".env" file to version control.
# ============================================================

# ------------------------------------------------------------------
# Google Maps Platform API Key (REQUIRED)
# ------------------------------------------------------------------
# Obtén tu clave en: https://console.cloud.google.com/
# Activa los servicios:
#   - Places API
#   - Maps JavaScript API (opcional, para verificar mapas)
#
# Precio: $200 USD de crédito gratis por mes (suficiente para miles
# de búsquedas). Más info: https://mapsplatform.google.com/pricing/
# ------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ------------------------------------------------------------------
# OpenAI API Key (OPCIONAL - solo si usas el modo --use-ai)
# ------------------------------------------------------------------
# Obtén tu clave en: https://platform.openai.com/api-keys
# Se usa para mejorar las consultas de búsqueda y validar datos.
# Si no tienes créditos de OpenAI, el script funciona sin IA (modo por defecto).
# ------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------------
# Configuración del modelo de OpenAI (OPCIONAL)
# ------------------------------------------------------------------
# Modelo a usar para el modo IA. Por defecto: gpt-4o-mini (más barato)
# Opciones: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# ------------------------------------------------------------------
OPENAI_MODEL=gpt-4o-mini
